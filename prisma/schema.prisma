generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String             @id @default(uuid())
  phoneNumber          String             @unique
  email                String?            @unique
  password             String?
  firstName            String?
  lastName             String?
  isProfileComplete    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  lastLogin            DateTime?
  role                 UserRole           @default(USER)
  resetPasswordExpiry  DateTime?
  resetPasswordToken   String?
  isActive             Boolean            @default(true)
  anfitrionaProfile    AnfitrioneProfile?
  conversationsAsUser1 Conversation[]     @relation("ConversationUser1")
  conversationsAsUser2 Conversation[]     @relation("ConversationUser2")
  depositRequests      DepositRequest[]
  histories            History[]
  historyViews         HistoryView[]
  image_unlocks        image_unlocks[]
  receivedLikes        Like[]             @relation("ReceivedLikes")
  givenLikes           Like[]             @relation("GivenLikes")
  messageUnlocks       MessageUnlock[]
  sentMessages         Message[]          @relation("SentMessages")
  wallet               Wallet?

  @@map("users")
}

model Conversation {
  id        String    @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             String          @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  read           Boolean         @default(false)
  createdAt      DateTime        @default(now())
  isLocked       Boolean         @default(false)
  price          Int?
  messageUnlocks MessageUnlock[]
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User            @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Like {
  id           String   @id @default(uuid())
  userId       String
  anfitrionaId String
  createdAt    DateTime @default(now())
  anfitriona   User     @relation("ReceivedLikes", fields: [anfitrionaId], references: [id], onDelete: Cascade)
  user         User     @relation("GivenLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, anfitrionaId])
  @@map("likes")
}

model AnfitrioneProfile {
  id             String            @id @default(uuid())
  userId         String            @unique
  dateOfBirth    DateTime
  cedula         String            @unique
  username       String            @unique
  idDocUrl       String?
  idDocPublicId  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  avatarUrl      String?
  avatarPublicId String?
  bio            String?
  rateCredits    Int?
  isOnline       Boolean           @default(false)
  images         AnfitrioneImage[]
  user           User              @relation(fields: [userId], references: [id])
  bank_accounts  bank_accounts[]
  servicePrices  ServicePrice[]

  @@map("anfitrione_profiles")
}

model AnfitrioneImage {
  id            String            @id @default(uuid())
  profileId     String
  url           String
  publicId      String?
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  isPremium     Boolean           @default(false)
  isVisible     Boolean           @default(true)
  unlockCredits Int?
  profile       AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  image_unlocks image_unlocks[]

  @@map("anfitrione_images")
}

model Wallet {
  id                  String                @id @default(uuid())
  balance             Decimal               @default(0.00) @db.Decimal(10, 2)
  userId              String                @unique
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  transactions        Transaction[]
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawal_requests withdrawal_requests[]

  @@map("wallets")
}

model Package {
  id             String           @id @default(uuid())
  name           String           @db.VarChar(100)
  credits        Int
  price          Decimal          @db.Decimal(10, 2)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  depositRequest DepositRequest[]

  @@map("packages")
}

model History {
  id           String        @id @default(uuid())
  userId       String
  mediaUrl     String
  mediaType    MediaType     @default(IMAGE)
  publicId     String?
  priceCredits Int           @default(0)
  publishedAt  DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  historyViews HistoryView[]

  @@map("histories")
}

model HistoryView {
  id        String   @id @default(uuid())
  userId    String
  historyId String
  viewedAt  DateTime @default(now())
  history   History  @relation(fields: [historyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, historyId])
  @@map("history_views")
}

model DepositRequest {
  id                  String         @id @default(uuid())
  userId              String
  packageId           String?
  paymentMethodId     String?
  amount              Decimal        @db.Decimal(10, 2)
  receiptUrl          String
  receiptPublicId     String?
  status              DepositStatus  @default(PENDING)
  rejectionReason     String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  creditsToDeliver    Int            @default(0)
  packageNameAtMoment String?
  package             Package?       @relation(fields: [packageId], references: [id])
  paymentMethod       PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction         Transaction?

  @@map("deposit_requests")
}

model PaymentMethod {
  id              String           @id @default(uuid())
  type            PaymentType
  bankName        String?
  accountName     String?
  accountNumber   String?
  qrImageUrl      String?
  qrPublicId      String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  logoPublicId    String?
  logoUrl         String?
  depositRequests DepositRequest[]

  @@map("payment_methods")
}

model Transaction {
  id               String          @id @default(uuid())
  walletId         String
  depositRequestId String?         @unique
  amount           Decimal         @db.Decimal(10, 2)
  type             TransactionType
  description      String?
  createdAt        DateTime        @default(now())
  image_unlocks    image_unlocks?
  messageUnlock    MessageUnlock?
  depositRequest   DepositRequest? @relation(fields: [depositRequestId], references: [id])
  wallet           Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model ServicePrice {
  id          String            @id @default(uuid())
  profileId   String
  serviceType ServiceType
  price       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  profile     AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, serviceType])
  @@map("service_prices")
}

model MessageUnlock {
  id            String       @id @default(uuid())
  messageId     String
  userId        String
  creditsSpent  Int
  transactionId String?      @unique
  unlockedAt    DateTime     @default(now())
  message       Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_unlocks")
}

model Banks {
  name          String
  logo_url      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime?
  id            Int             @id @default(autoincrement())
  bank_accounts bank_accounts[]
}

model bank_accounts {
  id                  BigInt                @id @default(autoincrement())
  userId              String
  bankId              Int
  anfitrionaProfileId String
  accountNumber       String                @db.VarChar(50)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime?
  accountHolderName   String?               @db.VarChar(100)
  anfitrione_profiles AnfitrioneProfile     @relation(fields: [anfitrionaProfileId], references: [id], onDelete: Cascade)
  Banks               Banks                 @relation(fields: [bankId], references: [id])
  withdrawal_requests withdrawal_requests[]

  @@index([accountNumber])
  @@index([bankId])
  @@index([userId])
}

model image_unlocks {
  id                String          @id
  imageId           String
  userId            String
  creditsSpent      Int
  transactionId     String?         @unique
  unlockedAt        DateTime        @default(now())
  anfitrione_images AnfitrioneImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  transactions      Transaction?    @relation(fields: [transactionId], references: [id])
  users             User            @relation(fields: [userId], references: [id])

  @@unique([imageId, userId])
}

model withdrawal_requests {
  id            String           @id
  walletId      String
  bankAccountId BigInt
  credits       Decimal          @db.Decimal(10, 2)
  soles         Decimal          @db.Decimal(10, 2)
  status        WithdrawalStatus @default(PENDING)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime
  bank_accounts bank_accounts    @relation(fields: [bankAccountId], references: [id])
  wallets       Wallet           @relation(fields: [walletId], references: [id])
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  MESSAGE_UNLOCK
  EARNING
  IMAGE_UNLOCK
}

enum ServiceType {
  MESSAGE
  CALL
  VIDEO_CALL
}

enum PaymentType {
  QR
  TRANSFERENCIA
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum UserRole {
  USER
  ADMIN
  ANFITRIONA
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}
