generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id @default(uuid())
  phoneNumber           String?                @unique
  email                 String?                @unique
  referralCode          String?                @unique
  password              String?
  firstName             String?
  lastName              String?
  isProfileComplete     Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  lastLogin             DateTime?
  role                  UserRole               @default(USER)
  resetPasswordExpiry   DateTime?
  resetPasswordToken    String?
  isActive              Boolean                @default(true)
  fcmToken              String?
  lastActiveAt          DateTime?
  anfitrionaProfile     AnfitrioneProfile?
  binanceDepositIntents BinanceDepositIntent[]
  conversationsAsUser1  Conversation[]         @relation("ConversationUser1")
  conversationsAsUser2  Conversation[]         @relation("ConversationUser2")
  depositRequests       DepositRequest[]
  histories             History[]
  historyViews          HistoryView[]
  imageUnlocks          ImageUnlock[]
  receivedLikes         Like[]                 @relation("ReceivedLikes")
  givenLikes            Like[]                 @relation("GivenLikes")
  messageImageUnlocks   MessageImageUnlock[]
  messageUnlocks        MessageUnlock[]
  sentMessages          Message[]              @relation("SentMessages")
  savedByUsers          SavedAnfitriona[]      @relation("SavedAnfitriona")
  savedAnfitrionas      SavedAnfitriona[]      @relation("SavedByUser")
  userProfile           UserProfile?
  subscriptions         UserSubscription[]
  wallet                Wallet?
  creatorReferralSetting      CreatorReferralSetting?
  referralsAsCreator          CreatorReferral[]           @relation("CreatorReferrer")
  referralAsReferred          CreatorReferral?            @relation("CreatorReferred")
  referralAsReferredCreator   CreatorReferral?            @relation("CreatorReferredCreator")
  referralRewardsAsReferrer   CreatorReferralRewardEvent[] @relation("RewardReferrerCreator")
  referralRewardsAsReferred   CreatorReferralRewardEvent[] @relation("RewardReferredUser")
  referralRewardsAsReferredCreator CreatorReferralRewardEvent[] @relation("RewardReferredCreator")
  referralRewardsAsPurchaseCreator CreatorReferralRewardEvent[] @relation("RewardPurchaseCreator")

  @@map("users")
}
 
model UserProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  userName       String?
  bio            String?
  avatarUrl      String?
  avatarPublicId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile")
}

model Conversation {
  id        String    @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id                  String               @id @default(uuid())
  conversationId      String
  senderId            String
  text                String?
  read                Boolean              @default(false)
  createdAt           DateTime             @default(now())
  isLocked            Boolean              @default(false)
  price               Float?
  imagePublicId       String?
  imageUrl            String?
  messageImageUnlocks MessageImageUnlock[]
  messageUnlocks      MessageUnlock[]
  conversation        Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender              User                 @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Like {
  id           String   @id @default(uuid())
  userId       String
  anfitrionaId String
  createdAt    DateTime @default(now())
  anfitriona   User     @relation("ReceivedLikes", fields: [anfitrionaId], references: [id], onDelete: Cascade)
  user         User     @relation("GivenLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, anfitrionaId])
  @@map("likes")
}

model SavedAnfitriona {
  id           String   @id @default(uuid())
  userId       String
  anfitrionaId String
  createdAt    DateTime @default(now())
  anfitriona   User     @relation("SavedAnfitriona", fields: [anfitrionaId], references: [id], onDelete: Cascade)
  user         User     @relation("SavedByUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, anfitrionaId])
  @@map("saved_anfitrionas")
}

model AnfitrioneProfile {
  id             String                  @id @default(uuid())
  userId         String                  @unique
  dateOfBirth    DateTime
  cedula         String                  @unique
  username       String                  @unique
  idDocUrl       String?
  idDocPublicId  String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  avatarUrl      String?
  avatarPublicId String?
  bio            String?
  rateCredits    Int?
  isOnline       Boolean                 @default(false)
  coverUrl       String?
  coverPublicId  String?
  images         AnfitrioneImage[]
  user           User                    @relation(fields: [userId], references: [id])
  subscription   AnfitrioneSubscription?
  bankAccounts   BankAccount[]
  servicePrices  ServicePrice[]
  socialLinks    AnfitrioneProfileSocialLink[]

  @@map("anfitrione_profiles")
}

model AnfitrioneImage {
  id            String            @id @default(uuid())
  profileId     String
  url           String
  publicId      String?
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  isPremium     Boolean           @default(false)
  isVisible     Boolean           @default(true)
  unlockCredits Float?
  profile       AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  imageUnlocks  ImageUnlock[]

  @@map("anfitrione_images")
}

model Wallet {
  id                 String              @id @default(uuid())
  balance            Decimal             @default(0.00) @db.Decimal(10, 2)
  userId             String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  transactions       Transaction[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawalRequests WithdrawalRequest[]

  @@map("wallets")
}

model Package {
  id                    String                 @id @default(uuid())
  name                  String                 @db.VarChar(100)
  credits               Int
  price                 Decimal                @db.Decimal(10, 2)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  binanceDepositIntents BinanceDepositIntent[]
  depositRequest        DepositRequest[]

  @@map("packages")
}

model BinanceDepositIntent {
  id               String              @id @default(uuid())
  userId           String
  packageId        String
  packageName      String
  creditsToDeliver Int
  network          String
  coin             String
  walletAddress    String
  expectedAmount   Decimal             @db.Decimal(20, 8)
  microDelta       Decimal             @db.Decimal(20, 8)
  txid             String?             @unique
  status           BinanceIntentStatus @default(PENDING)
  failureReason    String?
  binanceData      Json?
  expiresAt        DateTime
  confirmedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  package          Package             @relation(fields: [packageId], references: [id])
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, expiresAt])
  @@map("binance_deposit_intents")
}

model History {
  id           String        @id @default(uuid())
  userId       String
  mediaUrl     String
  mediaType    MediaType     @default(IMAGE)
  publicId     String?
  priceCredits Int           @default(0)
  publishedAt  DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  historyViews HistoryView[]

  @@map("histories")
}

model HistoryView {
  id        String   @id @default(uuid())
  userId    String
  historyId String
  viewedAt  DateTime @default(now())
  history   History  @relation(fields: [historyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, historyId])
  @@map("history_views")
}

model DepositRequest {
  id                  String         @id @default(uuid())
  userId              String
  packageId           String?
  paymentMethodId     String?
  amount              Decimal        @db.Decimal(10, 2)
  receiptUrl          String
  receiptPublicId     String?
  status              DepositStatus  @default(PENDING)
  rejectionReason     String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  creditsToDeliver    Int            @default(0)
  packageNameAtMoment String?
  package             Package?       @relation(fields: [packageId], references: [id])
  paymentMethod       PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction         Transaction?

  @@map("deposit_requests")
}

model PaymentMethod {
  id              String           @id @default(uuid())
  type            PaymentType
  bankName        String?
  accountName     String?
  accountNumber   String?
  qrImageUrl      String?
  qrPublicId      String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  logoPublicId    String?
  logoUrl         String?
  depositRequests DepositRequest[]

  @@map("payment_methods")
}

model Transaction {
  id                 String              @id @default(uuid())
  walletId           String
  depositRequestId   String?             @unique
  amount             Decimal             @db.Decimal(10, 2)
  type               TransactionType
  description        String?
  createdAt          DateTime            @default(now())
  imageUnlock        ImageUnlock?
  messageImageUnlock MessageImageUnlock?
  messageUnlock      MessageUnlock?
  referralSourceRewardEvent CreatorReferralRewardEvent? @relation("ReferralSourceTransaction")
  referralRewardTransactionEvent CreatorReferralRewardEvent? @relation("ReferralRewardTransaction")
  depositRequest     DepositRequest?     @relation(fields: [depositRequestId], references: [id])
  wallet             Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model CreatorReferral {
  id                String                @id @default(uuid())
  referrerCreatorId String
  referredUserId    String?               @unique
  referredCreatorId String?               @unique
  referralCodeUsed  String
  percent           Decimal               @default(0) @db.Decimal(5, 2)
  status            CreatorReferralStatus @default(ACTIVE)
  qualifiedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  referrerCreator   User                  @relation("CreatorReferrer", fields: [referrerCreatorId], references: [id], onDelete: Cascade)
  referredUser      User?                 @relation("CreatorReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  referredCreator   User?                 @relation("CreatorReferredCreator", fields: [referredCreatorId], references: [id], onDelete: Cascade)
  rewardEvents      CreatorReferralRewardEvent[]

  @@index([referrerCreatorId])
  @@index([referredCreatorId])
  @@map("creator_referrals")
}

model CreatorReferralSetting {
  id        String   @id @default(uuid())
  creatorId String   @unique
  percent   Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator   User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("creator_referral_settings")
}

model CreatorReferralRewardEvent {
  id                  String                      @id @default(uuid())
  referralId          String
  referrerCreatorId   String
  referredUserId      String?
  referredCreatorId   String?
  purchaseCreatorId   String?
  sourceTransactionId String                      @unique
  rewardTransactionId String                      @unique
  sourceAmount        Decimal                     @db.Decimal(10, 2)
  percent             Decimal                     @db.Decimal(5, 2)
  rewardAmount        Decimal                     @db.Decimal(10, 2)
  status              CreatorReferralRewardStatus @default(PAID)
  createdAt           DateTime                    @default(now())
  reversedAt          DateTime?
  referral            CreatorReferral             @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referrerCreator     User                        @relation("RewardReferrerCreator", fields: [referrerCreatorId], references: [id], onDelete: Cascade)
  referredUser        User?                       @relation("RewardReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  referredCreator     User?                       @relation("RewardReferredCreator", fields: [referredCreatorId], references: [id], onDelete: SetNull)
  purchaseCreator     User?                       @relation("RewardPurchaseCreator", fields: [purchaseCreatorId], references: [id], onDelete: SetNull)
  sourceTransaction   Transaction                 @relation("ReferralSourceTransaction", fields: [sourceTransactionId], references: [id], onDelete: Restrict)
  rewardTransaction   Transaction                 @relation("ReferralRewardTransaction", fields: [rewardTransactionId], references: [id], onDelete: Restrict)

  @@index([referralId])
  @@index([referrerCreatorId])
  @@index([referredUserId])
  @@index([referredCreatorId])
  @@map("creator_referral_reward_events")
}

model ServicePrice {
  id          String            @id @default(uuid())
  profileId   String
  serviceType ServiceType
  price       Float
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  profile     AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, serviceType])
  @@map("service_prices")
}

model MessageUnlock {
  id            String       @id @default(uuid())
  messageId     String
  userId        String
  creditsSpent  Float
  transactionId String?      @unique
  unlockedAt    DateTime     @default(now())
  message       Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_unlocks")
}

model MessageImageUnlock {
  id            String       @id @default(uuid())
  messageId     String
  userId        String
  creditsSpent  Float
  transactionId String?      @unique
  unlockedAt    DateTime     @default(now())
  imageUrl      String
  message       Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  user          User         @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_image_unlocks")
}

model ImageUnlock {
  id            String          @id @default(uuid())
  imageId       String
  userId        String
  creditsSpent  Float
  transactionId String?         @unique
  unlockedAt    DateTime        @default(now())
  image         AnfitrioneImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  transaction   Transaction?    @relation(fields: [transactionId], references: [id])
  user          User            @relation(fields: [userId], references: [id])

  @@unique([imageId, userId])
  @@map("image_unlocks")
}

model Banks {
  name         String
  logo_url     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime?     @updatedAt
  id           Int           @id @default(autoincrement())
  bankAccounts BankAccount[]
}

model BankAccount {
  id                  BigInt               @id @default(autoincrement())
  userId              String
  bankId              Int?
  anfitrionaProfileId String
  accountNumber       String?              @db.VarChar(50)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime?            @updatedAt
  accountHolderName   String?              @db.VarChar(100)
  type                WithdrawalMethodType @default(BCP)
  paypalEmail         String?
  anfitrionaProfile   AnfitrioneProfile    @relation(fields: [anfitrionaProfileId], references: [id], onDelete: Cascade)
  bank                Banks?               @relation(fields: [bankId], references: [id])
  withdrawalRequests  WithdrawalRequest[]

  @@index([userId])
  @@index([bankId])
  @@map("bank_accounts")
}

model AnfitrioneSubscription {
  id          String             @id @default(uuid())
  profileId   String             @unique
  price       Float
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  profile     AnfitrioneProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subscribers UserSubscription[]

  @@map("anfitrione_subscriptions")
}

model UserSubscription {
  id             String                 @id @default(uuid())
  userId         String
  subscriptionId String
  expiresAt      DateTime
  createdAt      DateTime               @default(now())
  subscription   AnfitrioneSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subscriptionId])
  @@map("user_subscriptions")
}

model WithdrawalRequest {
  id              String           @id @default(uuid())
  walletId        String
  bankAccountId   BigInt
  credits         Decimal          @db.Decimal(10, 2)
  soles           Decimal          @db.Decimal(10, 2)
  status          WithdrawalStatus @default(PENDING)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  receiptPublicId String?
  receiptUrl      String?
  rejectionReason String?
  payoutCurrency  String           @default("PEN")
  bankAccount     BankAccount      @relation(fields: [bankAccountId], references: [id])
  wallet          Wallet           @relation(fields: [walletId], references: [id])

  @@map("withdrawal_requests")
}

model SocialNetwork {
  id        String                          @id @default(uuid())
  name      String                          @unique
  icon      String?
  iconPublicId String?
  createdAt DateTime                        @default(now())
  updatedAt DateTime                        @updatedAt
  links     AnfitrioneProfileSocialLink[]

  @@map("social_networks")
}

model AnfitrioneProfileSocialLink {
  id                String            @id @default(uuid())
  anfitrionaProfileId String
  socialNetworkId   String
  url               String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  anfitrionaProfile AnfitrioneProfile @relation(fields: [anfitrionaProfileId], references: [id], onDelete: Cascade)
  socialNetwork     SocialNetwork     @relation(fields: [socialNetworkId], references: [id], onDelete: Cascade)

  @@unique([anfitrionaProfileId, socialNetworkId])
  @@map("anfitrione_profile_social_links")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  MESSAGE_UNLOCK
  EARNING
  IMAGE_UNLOCK
  CALL_PAYMENT
  MESSAGE_SEND
  SUBSCRIPTION
  CHAT_IMAGE_UNLOCK
  REFERRAL_CREATOR_REWARD
  REFERRAL_CREATOR_REWARD_REVERSAL
}

enum ServiceType {
  MESSAGE
  CALL
  VIDEO_CALL
  MESSAGE_SEND
}

enum PaymentType {
  QR
  TRANSFERENCIA
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum UserRole {
  USER
  ADMIN
  ANFITRIONA
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalMethodType {
  BCP
  OTHER_BANK
  PAYPAL
  BYBIT
  BINANCE
}

enum BinanceIntentStatus {
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
}

enum CreatorReferralStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum CreatorReferralRewardStatus {
  PAID
  REVERSED
}
