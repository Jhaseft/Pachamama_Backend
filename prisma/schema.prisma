generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String        @id @default(uuid())
  phoneNumber         String        @unique
  email               String?       @unique
  password            String?
  firstName           String?
  lastName            String?
  isProfileComplete   Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  lastLogin           DateTime?
  role                UserRole      @default(USER)
  resetPasswordExpiry DateTime?
  resetPasswordToken  String?
  bankAccounts        BankAccount[]
  kycDocuments        KycDocument[]
  kycRequests         KycRequest[]  @relation("KycRequestUser")
  kycReviewedRequests KycRequest[]  @relation("KycRequestReviewedBy")

  @@map("users")
}

model KycDocument {
  id            String            @id @default(uuid())
  userId        String
  kycRequestId  String
  docType       KycDocumentType
  docUrl        String?           // legacy
  publicId      String
  folder        String
  resourceType  KycResourceType
  mimeType      String?
  bytes         Int?
  uploadedAt    DateTime?         @default(now())

  user          User              @relation(fields: [userId], references: [id])
  kycRequest    KycRequest        @relation(fields: [kycRequestId], references: [id])

  @@unique([kycRequestId, docType])
  @@index([kycRequestId])
  @@map("kyc_documents")
}

model KycRequest {
  id           String    @id @default(uuid())
  userId       String
  status       KycStatus @default(PENDING)
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user        User  @relation("KycRequestUser", fields: [userId], references: [id])
  reviewedBy  User? @relation("KycRequestReviewedBy", fields: [reviewedById], references: [id])

  documents KycDocument[]

  @@map("kyc_requests")
}


model DepositDetail {
  id              String    @id @default(uuid())
  operationId     String    @unique
  expectedBOBH    Decimal   @db.Decimal(36, 18)
  // Safe proposal (multisig)
  safeTxHash      String?   @unique //identificador de la propuesta
  safeProposedAt  DateTime?
  mintTxHash      String?
  mintedAt        DateTime?
  proofUrl        String?
  proofUploadedAt DateTime?
  proofFileName   String?
  proofMimeType   String?
  reviewNote      String?
  reviewedById    String?
  reviewedAt      DateTime?


  @@map("deposit_details")
}

model BankAccount {
  id               BigInt             @id @default(autoincrement())
  userId           String
  bankId           Int
  accountNumber    String             @db.VarChar(50)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime?          @updatedAt
  bank             Banks              @relation(fields: [bankId], references: [id])
  user             User               @relation(fields: [userId], references: [id])


  @@index([userId])
  @@index([bankId])
  @@index([accountNumber])
  @@map("bank_accounts")
}

model Banks {
  name         String
  logo_url     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime?     @updatedAt
  country      country_banks
  id           Int           @id @default(autoincrement())
  bankAccounts BankAccount[]
}



model CompanyBankAccount {
  id            String       @id @default(uuid())
  currency      FiatCurrency    // Moneda a la que aplica esta cuenta (BOB / PEN)
  
  bankName      String       //banco X
  accountHolder String       //titular de la cuenta
  accountNumber String       //numero de cuenta 
  cci           String?      //útil para Perú cuenta interbancaria
  qrImageUrl    String?     // QR estático 
  qrPublicId    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("company_bank_accounts")
  @@unique([currency])      // 1 cuenta por moneda 
  @@index([currency])       // búsquedas rápidas por moneda
  @@index([bankName])
}

enum ContractEventType {
  MINTED
  BURNED
  REDEMPTION_REQUESTED
  REDEMPTION_FINALIZED
  REDEMPTION_REJECTED
  CONFISCATED
  SYSTEM_PAUSED
  SYSTEM_UNPAUSED
  ADDED_TO_BLACKLIST
  REMOVED_FROM_BLACKLIST
  TOKENS_RECOVERED
  TRANSFER                // Transferencias P2P entre usuarios
}

// Acciones posibles en el historial de blacklist
enum BlacklistAction {
  ADDED
  REMOVED
  CONFISCATED
}

enum UserRole {
  USER
  ADMIN
  ANFITRIONA
}

enum KycDocumentType {
  ID_FRONT
  ID_BACK
  LIVENESS_VIDEO
}

enum KycResourceType {
  image
  video
  raw
}

enum FiatOperationType {
  DEPOSIT
  WITHDRAW
}

enum FiatOperationStatus {
  PENDING
  PROOF_SUBMITTED
  NEED_CORRECTION
  RATE_EXPIRED
  APPROVED
  REJECTED
  PROCESSED
  FAILED
}

enum FiatCurrency {
  BOB
  PEN
}

enum TransactionType {
  MINT
  BURN
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum Network {
  BNB_CHAIN_MAINNET
  BNB_CHAIN_TESTNET
}

enum country_banks {
  Bolivia
  PERU
}

enum KycStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}
