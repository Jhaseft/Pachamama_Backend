generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String             @id @default(uuid())
  phoneNumber          String             @unique
  email                String?            @unique
  password             String?
  firstName            String?
  lastName             String?
  isProfileComplete    Boolean            @default(false)
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  lastLogin            DateTime?
  role                 UserRole           @default(USER)
  resetPasswordExpiry  DateTime?
  resetPasswordToken   String?
  wallet               Wallet?
  anfitrionaProfile    AnfitrioneProfile?
  histories            History[]
  historyViews         HistoryView[]
  givenLikes           Like[]             @relation("GivenLikes")
  receivedLikes        Like[]             @relation("ReceivedLikes")
  conversationsAsUser1 Conversation[]     @relation("ConversationUser1")
  conversationsAsUser2 Conversation[]     @relation("ConversationUser2")
  sentMessages         Message[]          @relation("SentMessages")
  depositRequests      DepositRequest[]
  messageUnlocks       MessageUnlock[]
  //notifications        Notification[]

  @@map("users")
}

model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1    User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             String  @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  read           Boolean @default(false)
  isLocked       Boolean @default(false) // la anfitriona activa el candado antes de enviar
  price          Int? // snapshot del precio al momento de enviar

  createdAt DateTime @default(now())

  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User            @relation("SentMessages", fields: [senderId], references: [id])
  messageUnlocks MessageUnlock[]

  @@map("messages")
}

model Like {
  id           String   @id @default(uuid())
  userId       String
  anfitrionaId String
  createdAt    DateTime @default(now())

  user       User @relation("GivenLikes", fields: [userId], references: [id], onDelete: Cascade)
  anfitriona User @relation("ReceivedLikes", fields: [anfitrionaId], references: [id], onDelete: Cascade)

  @@unique([userId, anfitrionaId])
  @@map("likes")
}

model AnfitrioneProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  dateOfBirth    DateTime
  cedula         String   @unique
  username       String   @unique
  idDocUrl       String?
  idDocPublicId  String?
  // Public profile fields
  avatarUrl      String?
  avatarPublicId String?
  bio            String?
  rateCredits    Int?
  isOnline       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User              @relation(fields: [userId], references: [id])
  images        AnfitrioneImage[]
  servicePrices ServicePrice[]
  bankAccounts  BankAccount[]

  @@map("anfitrione_profiles")
}

model AnfitrioneImage {
  id            String   @id @default(uuid())
  profileId     String
  url           String
  publicId      String?
  sortOrder     Int      @default(0)
  isPremium     Boolean  @default(false)
  unlockCredits Int? // null = gratuita; > 0 = créditos requeridos para desbloquear
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())

  profile AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("anfitrione_images")
}

model Wallet {
  id                  String              @id @default(uuid())
  balance             Decimal             @default(0.00) @db.Decimal(10, 2)
  userId              String              @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  withdrawalRequests  WithdrawalRequest[]

  @@map("wallets")
}

model Package {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  credits   Int
  price     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  depositRequest DepositRequest[]

  @@map("packages")
}

model History {
  id     String @id @default(uuid())
  userId String

  mediaUrl  String
  mediaType MediaType @default(IMAGE)
  publicId  String? // Para borrar de Cloudinary si es necesario

  priceCredits Int      @default(0) // Costo que el cliente debe pagar
  publishedAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  historyViews HistoryView[]

  @@map("histories")
}

model HistoryView {
  id        String   @id @default(uuid())
  userId    String
  historyId String
  viewedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  history History @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@unique([userId, historyId]) // Evita duplicados: un usuario ve una historia una vez
  @@map("history_views")
}

//MODELO QUE ALMACENA LA SOLICITUD DE DEPOSITO
model DepositRequest {
  id              String  @id @default(uuid())
  userId          String
  packageId       String?
  paymentMethodId String?

  packageNameAtMoment String?
  amount              Decimal @db.Decimal(10, 2)
  creditsToDeliver    Int     @default(0) //los creditos que el usuario recibira

  receiptUrl      String
  receiptPublicId String?
  status          DepositStatus @default(PENDING)
  rejectionReason String? // Por si el admin rechaza el pago (ej. "Foto borrosa")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  package       Package?       @relation(fields: [packageId], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  transaction   Transaction?
  //notifications Notification[]
  //refundDetail  RefundDetail?

  @@map("deposit_requests")
}

//MODELO QUE ALMACENA EL DETALLE DEL REEMBOLSO
/**
 * model RefundDetail {
 * id               String @id @default(uuid())
 * depositRequestId String @unique
 * //datos del cliente
 * clientAccount    String?
 * clientQrUrl      String?
 * clientQrPublicId String?
 * //datos que provee el admin al pagar
 * adminReceiptUrl      String?
 * adminReceiptPublicId String?
 * createdAt DateTime @default(now())
 * depositRequest DepositRequest @relation(fields: [depositRequestId], references: [id], onDelete: Cascade)
 * @@map("refund_details")
 * }
 */

// MODELO PARA ALMACENAR EL METODO DE PAGO
model PaymentMethod {
  id           String  @id @default(uuid())

  // Identidad Visual del método (Logo del banco o icono de billetera)
  logoUrl      String?
  logoPublicId String?

  type          PaymentType
  bankName      String? // Ej: "Banco Unión"
  accountName   String? // Titular: "Pachamama S.R.L."
  accountNumber String? // "1000000123"
  qrImageUrl    String? // Foto del QR
  qrPublicId    String?
  isActive      Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  depositRequests DepositRequest[]

  @@map("payment_methods")
}

// MODELO PARA ENVIAR NOTIFICACIONES AL CLIENTE O ADMIN
/**
 * model Notification {
 * id               String           @id @default(uuid())
 * userId           String
 * depositRequestId String?
 * title            String
 * message          String
 * read             Boolean          @default(false)
 * type             NotificationType
 * createdAt        DateTime         @default(now())
 * user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
 * depositRequest DepositRequest? @relation(fields: [depositRequestId], references: [id])
 * @@map("notifications")
 * }
 */

// MODELO QUE ACTUA COMO UN LIBRO CONTABLE (DETALLE DE MOVIMIENTO)
model Transaction {
  id               String  @id @default(uuid())
  walletId         String
  depositRequestId String? @unique
  amount           Decimal @db.Decimal(10, 2)

  type TransactionType

  description String?

  createdAt DateTime @default(now())

  wallet         Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  depositRequest DepositRequest? @relation(fields: [depositRequestId], references: [id])
  messageUnlock  MessageUnlock?

  @@map("transactions")
}

// PRECIOSJ DE SERVICIOS DE LA ANFITRJIONA (configurados en su perfil)
model ServicePrice {
  id          String      @id @default(uuid())
  profileId   String
  serviceType ServiceType
  price       Int // cuántos créditos cuesta este servicio
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  profile AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, serviceType]) // una anfitriona, un precio por tipo de servicio
  @@map("service_prices")
}

// REGISTRO DE MENSAJES DESBLOQUEADOS POR USUARIOS
model MessageUnlock {
  id            String   @id @default(uuid())
  messageId     String
  userId        String // el usuario que pagó para ver el mensaje
  creditsSpent  Int
  transactionId String?  @unique
  unlockedAt    DateTime @default(now())

  message     Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@unique([messageId, userId]) // un usuario desbloquea cada mensaje solo 1 vez
  @@map("message_unlocks")
}
model Banks {
  name         String
  logo_url     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime?     @updatedAt
  id           Int           @id @default(autoincrement())
  bankAccounts BankAccount[]
}
model BankAccount {
  id                  BigInt    @id @default(autoincrement())
  userId              String
  bankId              Int
  anfitrionaProfileId String
  accountNumber       String    @db.VarChar(50)
  accountHolderName   String?   @db.VarChar(100)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime? @updatedAt

  bank               Banks               @relation(fields: [bankId], references: [id])
  anfitrionaProfile  AnfitrioneProfile   @relation(fields: [anfitrionaProfileId], references: [id], onDelete: Cascade)
  withdrawalRequests WithdrawalRequest[]

  @@index([userId])
  @@index([bankId])
  @@index([accountNumber])
  @@map("bank_accounts")
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  walletId      String
  bankAccountId BigInt
  credits       Decimal          @db.Decimal(10, 2)
  soles         Decimal          @db.Decimal(10, 2)
  status        WithdrawalStatus @default(PENDING)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  wallet      Wallet      @relation(fields: [walletId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("withdrawal_requests")
}

enum TransactionType {
  DEPOSIT // Entrada de dinero (Recarga)
  WITHDRAWAL // Salida (Pago a anfitriona, suscripción, etc.)
  MESSAGE_UNLOCK // Pago para desbloquear un mensaje
  EARNING // Crédito recibido por la anfitriona
}

enum ServiceType {
  MESSAGE // Mensaje de chat
  CALL // Llamada de voz (futuro)
  VIDEO_CALL // Video llamada (futuro)
}

enum PaymentType {
  QR
  TRANSFERENCIA
}

//rechazado
/**
 * enum NotificationType {
 * DEPOSIT_APPROVED //notifica al cliente con deposito aprobado
 * DEPOSIT_REJECTED //notifica al cliente con deposito recahzado
 * NEW_MESSAGE
 * PROFILE_VERIFIED
 * REFUND_REQUESTED //notifica al admin
 * REFUND_PROCESSED //notifica al cliente
 * }
 */

enum DepositStatus {
  PENDING // Esperando aprobación
  APPROVED // ¡Éxito! Créditos sumados
  REJECTED // Error detectado por Admin (Aquí el usuario elige A o B)
  //REFUND_REQUESTED // El usuario pidió su dinero de vuelta tras el rechazo
  //REFUNDED // El Admin ya le devolvió el dinero al usuario
}

enum MediaType {
  IMAGE
  VIDEO
}

enum UserRole {
  USER
  ADMIN
  ANFITRIONA
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}
