generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(uuid())
  phoneNumber         String             @unique
  email               String?            @unique
  password            String?
  firstName           String?
  lastName            String?
  isProfileComplete   Boolean            @default(false)
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  lastLogin           DateTime?
  role                UserRole           @default(USER)
  resetPasswordExpiry DateTime?
  resetPasswordToken  String?
  wallet              Wallet?
  anfitrionaProfile   AnfitrioneProfile?
  histories           History[]
  historyViews        HistoryView[]
  givenLikes          Like[]             @relation("GivenLikes")
  receivedLikes       Like[]             @relation("ReceivedLikes")
  conversationsAsUser1 Conversation[]   @relation("ConversationUser1")
  conversationsAsUser2 Conversation[]   @relation("ConversationUser2")
  sentMessages         Message[]        @relation("SentMessages")

  @@map("users")
}

model Conversation {
  id        String    @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user1     User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model Like {
  id           String   @id @default(uuid())
  userId       String
  anfitrionaId String
  createdAt    DateTime @default(now())

  user       User @relation("GivenLikes", fields: [userId], references: [id], onDelete: Cascade)
  anfitriona User @relation("ReceivedLikes", fields: [anfitrionaId], references: [id], onDelete: Cascade)

  @@unique([userId, anfitrionaId])
  @@map("likes")
}

model AnfitrioneProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  dateOfBirth     DateTime
  cedula          String   @unique
  username        String   @unique
  idDocUrl        String?
  idDocPublicId   String?
  // Public profile fields
  avatarUrl       String?
  avatarPublicId  String?
  bio             String?
  rateCredits     Int?
  isOnline        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User              @relation(fields: [userId], references: [id])
  images AnfitrioneImage[]

  @@map("anfitrione_profiles")
}

model AnfitrioneImage {
  id            String   @id @default(uuid())
  profileId     String
  url           String
  publicId      String?
  sortOrder     Int      @default(0)
  isPremium     Boolean  @default(false)
  unlockCredits Int?     // null = gratuita; > 0 = créditos requeridos para desbloquear
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())

  profile AnfitrioneProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("anfitrione_images")
}
model Wallet {
  id        String   @id @default(uuid())
  balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Package {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  credits   Int
  price     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("packages")
}

model History {
  id        String   @id @default(uuid())
  userId    String   
  
  mediaUrl      String  
  mediaType     MediaType @default(IMAGE)
  publicId      String?  // Para borrar de Cloudinary si es necesario
  
  priceCredits  Int      @default(0) // Costo que el cliente debe pagar
  publishedAt   DateTime  @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  historyViews HistoryView[]

  @@map("histories")
}

model HistoryView {
  id         String   @id @default(uuid())
  userId     String   
  historyId  String   
  viewedAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  history    History  @relation(fields: [historyId], references: [id], onDelete: Cascade)

  @@unique([userId, historyId]) // Evita duplicados: un usuario ve una historia una vez
  @@map("history_views")
}

enum MediaType {
  IMAGE
  VIDEO
}

enum UserRole {
  USER
  ADMIN
  ANFITRIONA
}
